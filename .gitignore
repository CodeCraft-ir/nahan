# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# TWA / Bubblewrap (Android build) — NEVER commit signing keys or build output
twa/*.keystore
twa/*.jks
twa/*.keystore.b64
twa/*.apk
twa/*.aab
twa/node_modules/
# Generated Android project (recreated by twa/generate-project.mjs in CI)
twa/app/
twa/build/
twa/.gradle/
twa/gradle/
twa/gradlew
twa/gradlew.bat
twa/build.gradle
twa/settings.gradle
twa/gradle.properties
twa/manifest-checksum.txt
twa/store_icon.png
